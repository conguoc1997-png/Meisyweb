generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== MODULE KHO =====================

model SanPham {
  id        String   @id @default(cuid())
  ten       String
  sku       String   @unique
  mauSac    String?
  size      String?
  giaNhap   Float    @default(0)
  giaBan    Float    @default(0)
  tonKho    Int      @default(0)
  nguon     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nhapXuats   NhapXuatKho[]
  kocBookings KOCBooking[]
}

model NhapXuatKho {
  id        String   @id @default(cuid())
  sanPhamId String
  loai      String
  soLuong   Int
  ghiChu    String?
  nguoiTao  String?
  createdAt DateTime @default(now())

  sanPham SanPham @relation(fields: [sanPhamId], references: [id])
}

// ===================== MODULE ĐỔI TRẢ =====================

model DoiTra {
  id           String   @id @default(cuid())
  maDoiTra     String   @unique

  // Thông tin khách hàng
  sdtThangTruoc String? // SĐT tháng trước để phát hiện lạm dụng
  sdtHienTai    String?
  tenKhach      String
  diaChi        String?

  // Hàng hóa
  skuHienTai  String? // SKU đang có
  skuDoiSang  String? // SKU muốn đổi sang
  giaTriHang  Float   @default(0) // Giá trị khai với ĐVVC khi mất hàng

  // Phân loại vấn đề
  loaiVanDe String
  // doi_size | gui_nham | hang_loi | don_hang_loi | khac
  ghiChu    String?

  // Phí vận chuyển
  phiShip     Float  @default(0)   // 30000 nếu đổi size, 0 nếu lỗi shop
  soChieuShip Int    @default(2)   // 1 hoặc 2 chiều

  // Vận đơn
  maVanDon  String? // Mã vận đơn để theo dõi

  // Trạng thái xử lý
  trangThai String   @default("cho_xu_ly")
  // cho_xu_ly | dang_xu_ly | da_gui | hoan_thanh

  nguoiXuLy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== MODULE FEEDBACK =====================

model Feedback {
  id           String   @id @default(cuid())
  tenKhach     String?
  sdtKhach     String?
  sku          String?
  kenh         String   @default("khac") // shopee | tiktok | khac
  loai         String   // chat_lieu | size_form | mau_sac | dong_goi | van_chuyen | dich_vu | khac
  noiDung      String
  danhGia      Int?     // 1-5 sao (tuỳ chọn)
  nguoiGhiNhan String?
  createdAt    DateTime @default(now())
}

// ===================== MODULE BÙ TIỀN =====================

model BuTien {
  id           String   @id @default(cuid())
  tenKhach     String
  sdtKhach     String?
  loiBu        String   // giao_nham | hang_loi | thieu_hang | don_huy | khac
  soTien       Float    @default(0)
  trangThai    String   @default("cho_bu") // cho_bu | da_bu
  ghiChu       String?
  nguoiXuLy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ===================== MODULE KOC =====================

model KOC {
  id          String   @id @default(cuid())
  ten         String
  platform    String
  follower    Int      @default(0)
  giaCast     Float    @default(0)
  linkProfile String?
  sdt         String?
  email       String?
  ghiChu      String?
  createdAt   DateTime @default(now())

  bookings KOCBooking[]
}

// ===================== MODULE SẢN XUẤT =====================

model LoCat {
  id                 String    @id @default(cuid())
  ngay               DateTime
  hangCat            String
  soSize             String?
  maVai              String?
  soMSoDo            Float?
  soCay              Int       @default(1)
  cayData            String?   // JSON: [{soY,soM},...] khi soCay > 1
  soY                Float?
  soM                Float?
  tongSize           Int?
  soLa               Float?
  soLaThucTe         Int?
  soSanPham          Int?
  hangThucTe         Int?
  soLuongThieu       Int?
  xuongNhanHang      String?
  trangThai          String    @default("chua_xuat")
  xuong              String    @default("meisy")
  hdMay              Int?
  tonTruocMay        Float?
  hdMayDa            Boolean   @default(false)
  coGiat             String?
  hdGiatViSinh       Int?
  tonTruocGiatViSinh Float?
  hdGiatViSinhDa     Boolean   @default(false)
  hdGiatMau          Int?
  tonTruocGiatMau    Float?
  hdGiatMauDa        Boolean   @default(false)
  daCat              Boolean   @default(false) // đã hoàn thành cắt → xoá cây khỏi tồn kho
  ghiChuMay          String?   // ghi chú kiểu cách may
  mauGiat            String?   // màu giặt: NHẠT | ĐẬM | VI_SINH | KHÓI | CHÀM
  ghiChu             String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model VaiTon {
  id        String   @id @default(cuid())
  maVai     String   // mã vải / tên vải
  soMet     Float    @default(0) // tổng số mét (tự tính từ cayData)
  soCay     Int      @default(1) // số cây
  cayData   String?  // JSON: [{soMet: number}, ...]
  donVi     String   @default("m") // m | yard
  mauSac    String?  // màu vải
  xuong     String?  // xưởng tồn
  ghiChu    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HoaDonTonHistory {
  id          String   @id @default(cuid())
  loaiHD      String   // "may" | "giat_vi_sinh" | "giat_mau"
  soTonCu     Float
  soTonMoi    Float
  ghiChu      String?
  createdAt   DateTime @default(now())
}

model KOCBooking {
  id         String    @id @default(cuid())
  kocId      String
  sanPhamId  String?   // SKU sản phẩm gửi KOC
  soLuongGui Int       @default(0) // số lượng SP gửi KOC
  chiPhiCast Float     @default(0) // giá cast KOC
  chiPhiSP   Float     @default(0) // chi phí sản phẩm gửi (soLuongGui × giaNhap)
  chiPhi     Float     @default(0) // tổng = chiPhiCast + chiPhiSP
  ngayBat    DateTime
  ngayKet    DateTime?
  trangThai  String    @default("dang_chay")
  doanhThu   Float     @default(0)
  donHang    Int       @default(0)
  luotXem    Int       @default(0)
  ghiChu     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  koc     KOC      @relation(fields: [kocId], references: [id])
  sanPham SanPham? @relation(fields: [sanPhamId], references: [id])
}

model HoaDonTon {
  id        String   @id
  soTon     Float    @default(0)
  updatedAt DateTime @updatedAt
}
