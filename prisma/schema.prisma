generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===================== MODULE AUTH =====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("kho") // admin | kho | san_xuat
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== MODULE KHO =====================

model SanPham {
  id              String   @id @default(cuid())
  ten             String
  sku             String   @unique
  mauSac          String?
  size            String?
  giaNhap         Float    @default(0)
  giaBan          Float    @default(0)
  tonKho          Int      @default(0)
  nguon           String?
  tiktokProductId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  nhapXuats        NhapXuatKho[]
  kocBookings      KOCBooking[]
  tiktokDoanhThu   TiktokDoanhThuSP[]
}

model NhapXuatKho {
  id        String   @id @default(cuid())
  sanPhamId String
  loai      String
  soLuong   Int
  ghiChu    String?
  nguoiTao  String?
  createdAt DateTime @default(now())

  sanPham SanPham @relation(fields: [sanPhamId], references: [id])
}

// ===================== MODULE ĐỔI TRẢ =====================

model DoiTra {
  id           String   @id @default(cuid())
  maDoiTra     String   @unique

  // Thông tin khách hàng
  sdtThangTruoc String? // SĐT tháng trước để phát hiện lạm dụng
  sdtHienTai    String?
  tenKhach      String
  diaChi        String?

  // Hàng hóa
  skuHienTai  String? // SKU đang có
  skuDoiSang  String? // SKU muốn đổi sang
  giaTriHang  Float   @default(0) // Giá trị khai với ĐVVC khi mất hàng

  // Phân loại vấn đề
  loaiVanDe String
  // doi_size | gui_nham | hang_loi | don_hang_loi | khac
  ghiChu    String?

  // Phí vận chuyển
  phiShip     Float  @default(0)   // 30000 nếu đổi size, 0 nếu lỗi shop
  soChieuShip Int    @default(2)   // 1 hoặc 2 chiều

  // Nguồn kênh bán
  nguon     String? // shopee | tiktok | don_ngoai | khac

  // Vận đơn
  maVanDon  String? // Mã vận đơn để theo dõi

  // Trạng thái xử lý
  trangThai String   @default("cho_xu_ly")
  // cho_xu_ly | dang_xu_ly | da_gui | hoan_thanh

  nguoiXuLy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== MODULE FEEDBACK =====================

model Feedback {
  id           String   @id @default(cuid())
  tenKhach     String?
  sdtKhach     String?
  sku          String?
  kenh         String   @default("khac") // shopee | tiktok | khac
  loai         String   // chat_lieu | size_form | mau_sac | dong_goi | van_chuyen | dich_vu | khac
  noiDung      String
  danhGia      Int?     // 1-5 sao (tuỳ chọn)
  nguoiGhiNhan String?
  daXem        Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ===================== MODULE BÙ TIỀN =====================

model BuTien {
  id           String   @id @default(cuid())
  tenKhach     String
  sdtKhach     String?
  loiBu        String   // giao_nham | hang_loi | thieu_hang | don_huy | khac
  soTien       Float    @default(0)
  trangThai    String   @default("cho_bu") // cho_bu | da_bu
  ghiChu       String?
  nguoiXuLy    String?
  nguon        String?  // shopee | tiktok | khac
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UngTien {
  id        String   @id @default(cuid())
  soTien    Float    @default(0)
  thang     String   // YYYY-MM
  ghiChu    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== MODULE KOC =====================

model KOC {
  id          String   @id @default(cuid())
  ten         String
  platform    String
  follower    Int      @default(0)
  giaCast     Float    @default(0)
  linkProfile String?
  sdt         String?
  email       String?
  diaChi      String?
  ghiChu          String?
  trangThaiHopTac String   @default("chua_tra_loi")
  createdAt       DateTime @default(now())

  bookings       KOCBooking[]
  tiktokDoanhThu TiktokDoanhThuKOC[]
}

// ===================== MODULE SẢN XUẤT =====================

model LoCat {
  id                 String    @id @default(cuid())
  ngay               DateTime
  hangCat            String
  soSize             String?
  maVai              String?
  soMSoDo            Float?
  soCay              Int       @default(1)
  cayData            String?   // JSON: [{soY,soM},...] khi soCay > 1
  soY                Float?
  soM                Float?
  tongSize           Int?
  soLa               Float?
  soLaThucTe         Int?
  soSanPham          Int?
  hangThucTe         Int?
  ngayNhanHang       DateTime? // ngày nhận hàng thực tế (tách khỏi ngày cắt)
  soLuongThieu       Int?
  xuongNhanHang      String?
  trangThai          String    @default("chua_xuat")
  xuong              String    @default("meisy")
  hdMay              Int?
  tonTruocMay        Float?
  hdMayDa            Boolean   @default(false)
  coGiat             String?
  hdGiatViSinh       Int?
  tonTruocGiatViSinh Float?
  hdGiatViSinhDa     Boolean   @default(false)
  hdGiatMau          Int?
  tonTruocGiatMau    Float?
  hdGiatMauDa        Boolean   @default(false)
  xuatHoaDonDa       Boolean   @default(false) // đã xuất hoá đơn cho lô này
  loaiHang           String?   @default("dai_thuong") // Dài thường | Dài kiểu | Short
  daCat              Boolean   @default(false) // đã hoàn thành cắt → xoá cây khỏi tồn kho
  ghiChuMay          String?   // ghi chú kiểu cách may
  mauGiat            String?   // màu giặt: NHẠT | ĐẬM | VI_SINH | KHÓI | CHÀM
  ghiChu             String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model VaiTon {
  id              String   @id @default(cuid())
  maVai           String   // mã vải / tên vải
  soMet           Float    @default(0) // tổng số mét (tự tính từ cayData)
  soCay           Int      @default(1) // số cây
  cayData         String?  // JSON: [{soMet: number}, ...]
  donVi           String   @default("m") // m | yard
  mauSac          String?  // màu vải
  xuong           String?  // xưởng tồn
  ghiChu          String?
  // ── Công nợ NCC ──
  tenNCC          String?  // tên nhà cung cấp
  soHoaDon        String?  // số hoá đơn
  chiPhiThucNhap  Float?   // chi phí thực tế
  soTienHoaDon    Float?   // tiền trên hoá đơn (có thể khác thực tế)
  vatPct          Float?   // VAT % (null = không có VAT)
  tinhNoTheo      String   @default("thuc_te") // "thuc_te" | "hoa_don"
  congNoNccId     String?  // link tới CongNoNCC tạo tự động
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model HoaDonTonHistory {
  id          String   @id @default(cuid())
  loaiHD      String   // "may" | "giat_vi_sinh" | "giat_mau"
  soTonCu     Float
  soTonMoi    Float
  ghiChu      String?
  createdAt   DateTime @default(now())
}

model KOCBooking {
  id         String    @id @default(cuid())
  kocId      String
  sanPhamId  String?
  soLuongGui Int       @default(0)
  chiPhiCast Float     @default(0)
  chiPhiSP   Float     @default(0)
  chiPhi     Float     @default(0)
  ngayBat    DateTime
  ngayKet    DateTime?
  trangThai    String    @default("dang_chay")
  loai         String    @default("booking")
  doanhThu     Float     @default(0)
  donHang      Int       @default(0)
  luotXem      Int       @default(0)
  ghiChu       String?
  ngayRaHang   DateTime?
  ngayLenVideo DateTime?
  daSent       Boolean   @default(false)
  daRecv       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  koc           KOC      @relation(fields: [kocId], references: [id])
  sanPham       SanPham? @relation(fields: [sanPhamId], references: [id])
  doanhThuThang BookingDoanhThuThang[]
}

model BookingDoanhThuThang {
  id        String   @id @default(cuid())
  bookingId String
  thang     String   // "2026-05"
  doanhThu  Float    @default(0)
  donHang   Int      @default(0)
  hoanTien  Float    @default(0)
  hoaHong   Float    @default(0)
  soMon     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking KOCBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, thang])
}

// Doanh thu TikTok theo sản phẩm mỗi tháng (tổng hợp từ tất cả KOC)
model TiktokDoanhThuSP {
  id          String   @id @default(cuid())
  sanPhamId   String
  thang       String   // "2026-05"
  doanhThu    Float    @default(0)
  donHang     Int      @default(0)
  hoanTien    Float    @default(0)
  hoaHong     Float    @default(0)
  soMon       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sanPham SanPham @relation(fields: [sanPhamId], references: [id], onDelete: Cascade)

  @@unique([sanPhamId, thang])
}

// Doanh thu TikTok theo KOC mỗi tháng
model TiktokDoanhThuKOC {
  id              String   @id @default(cuid())
  kocId           String
  thang           String   // "2026-05"
  creatorName     String   // tên gốc từ file TikTok
  tiktokProductId String?  // ID sản phẩm TikTok (để lọc theo sản phẩm)
  doanhThu        Float    @default(0)
  donHang         Int      @default(0)
  hoanTien        Float    @default(0)
  hoaHong         Float    @default(0)
  soMon           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  koc KOC @relation(fields: [kocId], references: [id], onDelete: Cascade)

  @@unique([kocId, thang, tiktokProductId])
}

model HoaDonTon {
  id        String   @id
  soTon     Float    @default(0)
  updatedAt DateTime @updatedAt
}

// ===================== MODULE NHÀ CUNG CẤP =====================

model NhaCungCap {
  id        String   @id @default(cuid())
  ma        String   @unique
  ten       String
  sdt       String?
  diaChi    String?
  email     String?
  ghiChu    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Quy đổi đơn vị: 1 gói = 100 chiếc, 1 cuộn = 500m...
model QuyDoiDonVi {
  id        String   @id @default(cuid())
  tuDonVi   String   // đơn vị nguồn (goi, cuon, hop...)
  veDonVi   String   // đơn vị đích (chiec, m, cai...)
  heSo      Float    // 1 tuDonVi = heSo veDonVi
  ghiChu    String?
  createdAt DateTime @default(now())
}

// ===================== MODULE XUẤT KHO NPL =====================

// Định mức NPL theo loại hàng (BOM)
model DinhMucNPL {
  id        String   @id @default(cuid())
  hangCat   String   // mã/tên loại hàng, e.g. "Áo sơ mi", "Quần short"
  vatTuId   String
  soLuong   Float    // định mức / 1 sản phẩm (theo đơn vị cơ bản)
  haoHui    Float    @default(0)   // % hao hụt (VD: 3 = 3%), tự động cộng vào khi xuất
  donViMua  String   @default("m") // đơn vị mua (có thể khác đơn vị cơ bản)
  quyDoi    Float    @default(1)   // hệ số quy đổi sang đơn vị cơ bản
  ghiChu    String?
  createdAt DateTime @default(now())

  vatTu VatTu @relation(fields: [vatTuId], references: [id])
}

// Phiếu xuất kho NPL (liên kết lô cắt)
model PhieuXuatKho {
  id            String    @id @default(cuid())
  soPhieu       String    @unique
  loCatId       String?   // lô cắt tương ứng
  hangCat       String?   // loại hàng cắt
  soSanPham     Int       @default(0) // số SP thực tế của lô
  ngay          DateTime
  ho            String    @default("meisy") // "meisy" | "nguyen_cong_uoc"
  lyDo          String    @default("san_xuat") // san_xuat | ban_hang | dieu_chinh | khac
  tenKhachHang  String?   // tên khách hàng mua (khi lyDo = ban_hang)
  giaBanTong    Float?    // tổng giá bán (tính từ chi tiết × giaBan)
  ghiChu        String?
  nguoiTao      String?
  createdAt     DateTime  @default(now())

  // Trạng thái hủy
  trangThai  String    @default("active")  // active | da_huy
  lyHuy      String?   // lý do hủy (vd: "Hoàn hóa đơn #123")
  ngayHuy    DateTime?
  nguoiHuy   String?

  chiTiet         PhieuXuatChiTiet[]
  doanhThu        DoanhThu?
}

// Chi tiết phiếu xuất
model PhieuXuatChiTiet {
  id          String @id @default(cuid())
  phieuXuatId String
  vatTuId     String
  soLuong     Float
  donGia      Float  @default(0) // giá vốn bình quân tại thời điểm xuất
  thanhTien   Float  @default(0)
  giaBan      Float  @default(0) // giá bán / đơn vị (lấy từ VatTu.giaBan, có thể sửa)
  doanhThuCt  Float  @default(0) // = soLuong × giaBan
  ghiChu      String?

  phieu PhieuXuatKho @relation(fields: [phieuXuatId], references: [id], onDelete: Cascade)
  vatTu VatTu        @relation(fields: [vatTuId], references: [id])
}

// ===================== MODULE KẾ TOÁN =====================

// Danh mục nguyên phụ liệu
model VatTu {
  id        String   @id @default(cuid())
  ma        String   @unique
  ten       String
  loai      String   // "vai" | "phu_lieu"
  nhom      String?  // chi | cuc | khoa_keo | mex | nhan | dong_goi | vai_cotton | vai_thun | khac
  donVi     String   @default("m")    // đơn vị tồn kho (cơ bản): m | chiếc | kg...
  donViMua  String   @default("m")    // đơn vị mua thường dùng: cây | gói | cuộn...
  quyDoi    Float    @default(1)      // 1 donViMua = quyDoi donVi (VD: 1 cây = 50m)
  giaBan    Float?                    // giá bán (dùng cho xuất kho → doanh thu)
  ghiChu    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tonKho      TonKhoVatTu?
  chiTiet     ChiTietNhapKho[]
  dinhMuc     DinhMucNPL[]
  xuatChiTiet PhieuXuatChiTiet[]
}

// Tồn kho nguyên phụ liệu (1 dòng / vật tư)
model TonKhoVatTu {
  id             String   @id @default(cuid())
  vatTuId        String   @unique
  soLuong        Float    @default(0)
  giaTrungBinh   Float    @default(0) // giá vốn bình quân gia quyền
  giaTriTon      Float    @default(0) // = soLuong × giaTrungBinh
  updatedAt      DateTime @updatedAt

  vatTu VatTu @relation(fields: [vatTuId], references: [id])
}

// Phiếu nhập kho
model PhieuNhapKho {
  id              String    @id @default(cuid())
  soPhieu         String    @unique
  ngay            DateTime
  ho              String    @default("meisy") // "meisy" | "nguyen_cong_uoc"
  nhaCC           String    // "hac_long" | "an_huy" | "viet_hoa" | custom
  tenNhaCC        String?
  soHoaDon        String?
  ngayHoaDon      DateTime?
  tongTien        Float     @default(0)
  soTienHoaDon    Float?    // tiền trên hoá đơn NCC xuất
  chiPhiThucNhap  Float?    // chi phí thực tế nhận hàng (có thể khác hoá đơn)
  trangThai       String    @default("chua_thanh_toan") // chua_thanh_toan | da_thanh_toan | thanh_toan_1_phan
  ghiChu          String?
  nguoiTao        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  chiTiet ChiTietNhapKho[]
}

// Chi tiết phiếu nhập (từng dòng vật tư)
model ChiTietNhapKho {
  id          String  @id @default(cuid())
  phieuId     String
  vatTuId     String
  soLuongMua  Float   @default(0) // số lượng theo đơn vị mua (cây, kg, m...)
  donViMua    String  @default("m") // đơn vị mua: m | cay | kg
  quyDoi      Float   @default(1)   // hệ số: soLuong = soLuongMua × quyDoi
  donViQuyDoi String? @default("")  // đơn vị sau quy đổi (m, chiếc...) — lưu từ form nhập
  soLuong     Float   // tổng theo đơn vị tồn kho (m)
  donGia      Float   // giá / donViMua
  vat         Float   @default(0)   // thuế VAT %
  thanhTien   Float
  ghiChu      String?

  phieu PhieuNhapKho @relation(fields: [phieuId], references: [id], onDelete: Cascade)
  vatTu VatTu        @relation(fields: [vatTuId], references: [id])
}

model CongNo {
  id         String   @id @default(cuid())
  nhaCC      String   // "hac_long" | "an_huy" | "viet_hoa"
  ngay       DateTime
  soChungTu  String?  // Số hoá đơn / chứng từ
  dienGiai   String   // Diễn giải giao dịch
  loai       String   // "mua_hang" | "tra_tien" | "dieu_chinh_no" | "dieu_chinh_co"
  soTien     Float    @default(0)
  ghiChu     String?
  nguoiTao   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ===================== MODULE ĐỐI SOÁT HOÀN TRẢ =====================

// ===================== MODULE CHẤM CÔNG =====================

model NhanVien {
  id         String     @id @default(cuid())
  maNV       String     @unique
  ten        String
  chucVu     String?
  phongBan   String?
  loaiLuong       String  @default("co_ban") // co_ban | khoan
  luongCB         Float?
  phuCapChuyenCan Float?  // phụ cấp chuyên cần cố định/tháng
  phuCapAn        Float?  // phụ cấp ăn mỗi ngày (chỉ tính ngày đi làm đủ)
  phuCapDacBiet   Float?  // phụ cấp đặc biệt cố định/tháng
  heSoTC          Float   @default(1.5) // hệ số tăng ca
  ngaySinh        DateTime? // ngày sinh nhật
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  chamCongs  ChamCong[]
  luongCBHistory LuongCBHistory[]
}

// Lịch sử thay đổi Lương CB — áp dụng từ 1 tháng cụ thể, không ảnh hưởng các tháng trước
model LuongCBHistory {
  id          String   @id @default(cuid())
  nhanVienId  String
  luongCB     Float
  thangApDung String   // "2026-03" — áp dụng từ tháng này trở đi
  createdAt   DateTime @default(now())

  nhanVien NhanVien @relation(fields: [nhanVienId], references: [id], onDelete: Cascade)

  @@unique([nhanVienId, thangApDung])
}

model ChamCong {
  id         String   @id @default(cuid())
  nhanVienId String
  ngay       DateTime // chỉ lấy phần ngày (date)
  trangThai  String   @default("di_lam")
  // di_lam | nghi_phep | vang | di_muon | nua_ngay | nghi_le
  tangCa     Float?   // số giờ tăng ca (null = không TC)
  ghiChu     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  nhanVien NhanVien @relation(fields: [nhanVienId], references: [id])

  @@unique([nhanVienId, ngay])
}

// ===================== MODULE SỔ THU CHI =====================

// Số dư tài khoản quỹ theo hộ
model TaiKhoanQuy {
  id        String    @id @default(cuid())
  ho        String    @unique // "meisy" | "nguyen_cong_uoc"
  tenHo     String
  soDuDauKy Float     @default(0) // số dư đầu kỳ (nhập tay mỗi tháng)
  thang     String    @default("2026-06") // tháng hiện tại đang theo dõi
  daChot    Boolean   @default(false) // đã chốt tháng (khóa chỉnh sửa)
  ngayChot  DateTime? // ngày chốt
  updatedAt DateTime  @updatedAt
}

// Phiếu thu chi (đề xuất → duyệt → đã chi)
model PhieuThuChi {
  id          String    @id @default(cuid())
  ho          String    // "meisy" | "nguyen_cong_uoc"
  loai        String    // "thu" | "chi"
  soTien      Float     @default(0)
  danhMuc     String    @default("khac")
  // "luong" | "van_phong" | "nguyen_lieu" | "van_chuyen" | "dien_nuoc" | "thue" | "khac"
  dienGiai    String    // mô tả chi tiết
  nguoiDeXuat String?   // tên người đề xuất
  trangThai   String    @default("cho_duyet")
  // "cho_duyet" | "da_duyet" | "tu_choi" | "da_chi"
  ghiChuDuyet String?
  ngay        DateTime  @default(now()) // ngày phát sinh
  thang       String    // "2026-06" để lọc theo tháng
  nguoiDuyet  String?
  ngayDuyet   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ===================== MODULE CÔNG NỢ & DOANH THU =====================

// Doanh thu từ xuất kho bán hàng
model DoanhThu {
  id              String    @id @default(cuid())
  ho              String    // "meisy" | "nguyen_cong_uoc"
  ngay            DateTime
  thang           String    // "2026-06"
  phieuXuatId     String?   @unique // liên kết phiếu xuất kho
  tenKhachHang    String?
  soTien          Float     @default(0) // tổng doanh thu (giaBan × soLuong)
  giaVon          Float     @default(0) // tổng giá vốn (donGia × soLuong)
  loiNhuan        Float     @default(0) // lợi nhuận = soTien - giaVon
  trangThai       String    @default("chua_thu") // chua_thu | da_thu
  ghiChu          String?
  nguoiTao        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  phieuXuat       PhieuXuatKho?       @relation(fields: [phieuXuatId], references: [id])
  congNoKhachHang CongNoKhachHang?
}

// Công nợ khách hàng (accounts receivable) — tạo khi xuất kho có tên KH
model CongNoKhachHang {
  id              String    @id @default(cuid())
  ho              String    // "meisy" | "nguyen_cong_uoc"
  ngay            DateTime
  thang           String    // "2026-06"
  tenKhachHang    String
  doanhThuId      String?   @unique
  soTien          Float     @default(0) // tổng nợ
  daTra           Float     @default(0) // đã thanh toán
  conLai          Float     @default(0) // còn lại
  trangThai       String    @default("con_no") // con_no | da_thanh_toan | thanh_toan_1_phan
  phieuThuChiId   String?   // liên kết PhieuThuChi khi nhận tiền
  ghiChu          String?
  nguoiTao        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  doanhThu        DoanhThu? @relation(fields: [doanhThuId], references: [id])
}

// Công nợ NCC mới — theo hộ, tách hoá đơn vs thực tế
model CongNoNCC {
  id              String    @id @default(cuid())
  ho              String    // "meisy" | "nguyen_cong_uoc"
  ngay            DateTime
  thang           String    // "2026-06"
  tenNCC          String
  phieuNhapId     String?   // liên kết PhieuNhapKho (tuỳ chọn)
  soHoaDon        String?
  soTienHoaDon    Float     @default(0) // tiền trên hoá đơn
  chiPhiThucNhap  Float     @default(0) // chi phí thực tế nhận hàng
  daTra           Float     @default(0) // đã thanh toán
  conLai          Float     @default(0) // còn nợ (= chiPhiThucNhap - daTra)
  trangThai       String    @default("con_no") // con_no | da_thanh_toan | thanh_toan_1_phan
  phieuThuChiId   String?   // liên kết PhieuThuChi khi trả nợ
  ghiChu          String?
  nguoiTao        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ===================== MODULE ĐỐI SOÁT HOÀN TRẢ =====================

model DonHoanTra {
  id          String    @id @default(cuid())
  maDon       String    // Mã đơn hàng từ sàn
  san         String    @default("shopee") // shopee | tiktok | lazada
  tenSP       String    @default("")
  sku         String    @default("")
  soLuong     Int       @default(1)
  ngayTaoDon  DateTime? // Ngày tạo đơn trên sàn
  lyDoHoan    String?   // Lý do hoàn trả
  trangThai   String    @default("cho_ve") // cho_ve | da_ve | loi | huy
  daDoiSoat   Boolean   @default(false)   // Đã tick kiểm tra thực tế
  ghiChu      String?
  batchId     String?   // Nhóm import cùng đợt
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ===================== MODULE FAKE KHO =====================

model FakeKho {
  id            String    @id @default(cuid())
  sku           String
  tenSanPham    String?
  sanPhamId     String?
  ngayNhap      DateTime
  soLuongNhap   Int       @default(0)
  ngayRaHang    DateTime?
  soLuongRa     Int       @default(0)
  ghiChu        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
